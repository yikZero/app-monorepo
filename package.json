{
  "name": "@onekeyhq/app-monorepo",
  "packageManager": "yarn@4.12.0",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "setup:env": "node -e \"const fs=require('fs');if(!fs.existsSync('.env'))fs.copyFileSync('.env.example','.env');\"",
    "postinstall": "node development/scripts/postinstall.js",
    "copy:inject": "node development/scripts/copy-injected.js",
    "app:desktop": "yarn workspace @onekeyhq/desktop start",
    "app:desktop:rspack": "yarn workspace @onekeyhq/desktop start:rspack",
    "app:desktop:web": "yarn workspace @onekeyhq/desktop dev:renderer",
    "app:desktop:web:rspack": "yarn workspace @onekeyhq/desktop dev:renderer:rspack",
    "app:desktop:electron": "yarn workspace @onekeyhq/desktop build:main:dev && yarn workspace @onekeyhq/desktop dev:main",
    "app:desktop:build": "yarn workspace @onekeyhq/desktop build",
    "app:ext": "yarn workspace @onekeyhq/ext start:v3",
    "app:ext:rspack": "yarn workspace @onekeyhq/ext start:v3:rspack",
    "app:ext:proxy": "yarn workspace @onekeyhq/ext start:v3:proxy",
    "app:ext:build": "yarn workspace @onekeyhq/ext build:v3",
    "app:ext:build:rspack": "yarn workspace @onekeyhq/ext build:v3:rspack",
    "app:ext:build:all": "yarn workspace @onekeyhq/ext build:all:v3",
    "app:web": "yarn app:web:no-proxy",
    "app:web:rspack": "yarn workspace @onekeyhq/web start:rspack",
    "app:web:3030": "WEB_PORT=3030 yarn app:web:no-proxy",
    "app:web:proxy": "yarn workspace @onekeyhq/web start:proxy",
    "app:web:no-proxy": "yarn workspace @onekeyhq/web start",
    "app:web:build": "yarn workspace @onekeyhq/web build",
    "app:web:build:rspack": "yarn workspace @onekeyhq/web build:rspack",
    "app:web-embed": "yarn workspace @onekeyhq/web-embed start",
    "app:web-embed:build": "yarn workspace @onekeyhq/web-embed build",
    "app:native-bundle": "cross-env NODE_OPTIONS=\"--max-old-space-size=8192\" yarn workspace @onekeyhq/mobile native-bundle",
    "app:split-bundle": "yarn workspace @onekeyhq/mobile split-bundle",
    "app:build-bundle": "yarn workspace @onekeyhq/mobile build-bundle",
    "app:ios": "yarn workspace @onekeyhq/mobile ios",
    "app:ios:device": "yarn workspace @onekeyhq/mobile ios:device",
    "app:ios:pod-install": "yarn workspace @onekeyhq/mobile ios:pod-install",
    "app:android": "cross-env NODE_OPTIONS=\"--max-old-space-size=8192\" yarn workspace @onekeyhq/mobile android",
    "app:android:device": "cross-env NODE_OPTIONS=\"--max-old-space-size=8192\" yarn workspace @onekeyhq/mobile android:device",
    "perf:server": "node development/performance-server/server.js",
    "perf:ios:debug": "node development/perf-ci/run-ios-perf-detox-debug.js",
    "perf:ios:release": "node development/perf-ci/run-ios-perf-detox-release.js",
    "perf:ios:release:daemon": "node development/perf-ci/run-ios-perf-detox-release-daemon.js",
    "perf:android:debug": "node development/perf-ci/run-android-perf-detox-debug.js",
    "perf:android:release": "node development/perf-ci/run-android-perf-detox-release.js",
    "perf:android:release:daemon": "node development/perf-ci/run-android-perf-detox-release-daemon.js",
    "perf:web:release": "node development/perf-ci/run-web-perf-release.js",
    "perf:web:release:daemon": "node development/perf-ci/run-web-perf-release-daemon.js",
    "perf:web:prepare": "node development/perf-ci/run-web-perf-prepare.js",
    "perf:desktop:release": "node development/perf-ci/run-desktop-perf-release.js",
    "perf:desktop:release:daemon": "node development/perf-ci/run-desktop-perf-release-daemon.js",
    "perf:ext:release": "node development/perf-ci/run-ext-perf-release.js",
    "perf:ext:release:daemon": "node development/perf-ci/run-ext-perf-release-daemon.js",
    "icon:build": "yarn workspace @onekeyhq/components icon:build",
    "i18n:pull": "yarn op yarn workspace @onekeyhq/shared i18n:pull",
    "i18n:add": "yarn op yarn workspace @onekeyhq/shared i18n:add",
    "i18n:search": "yarn workspace @onekeyhq/shared i18n:search",
    "clean": "yarn workspaces foreach -A  -p run clean && node ./development/scripts/clean_workspace.js",
    "clean:cache": "yarn workspaces foreach -A run clean:build",
    "patch:fix": "node development/patch-fix.js",
    "_tsc": "node ./development/lint/ts",
    "reinstall": "yarn clean && yarn install",
    "_lint": "node ./development/lint/eslint",
    "_electron": "node ./development/lint/electron",
    "_lang": "node ./development/lint/lang",
    "_folder": "yarn workspaces foreach -A -p --topological-dev run _folderslint",
    "_packageVersions": "node ./development/lint/package-versions.js",
    "_font": "node ./development/lint/font.js",
    "lint:project": "yarn _tsc && yarn _lint && concurrently --kill-others-on-fail \"yarn _electron\" \"yarn _folder\" \"yarn _lang\" \"yarn _packageVersions\" \"yarn _font\"",
    "lint": "yarn lint:project",
    "eslint": "npx eslint . --ext .ts,.tsx --fix --cache --cache-location \"$(yarn config get cacheFolder)\"/.eslintcache'",
    "oxlint": "npx oxlint --tsconfig ./tsconfig.json --type-aware . --fix",
    "lint:only": "npx oxlint --tsconfig ./tsconfig.json --type-aware . --fix --deny-warnings",
    "lint:staged": "git diff --cached --name-only --diff-filter=ACMR | grep -E '\\.(ts|tsx)$' | xargs -r npx oxlint --tsconfig ./tsconfig.json --type-aware --fix --deny-warnings",
    "tsc:only": "npx tsgo -p ./tsconfig.json --noEmit --tsBuildInfoFile \"$(yarn config get cacheFolder)\"/.app-mono-ts-cache --pretty",
    "tsc:staged": "npx tsgo -p ./tsconfig.json --noEmit --tsBuildInfoFile \"$(yarn config get cacheFolder)\"/.app-mono-ts-cache --pretty",
    "test": "yarn jest",
    "op": "./development/scripts/op-run.sh",
    "app:web:op": "yarn op yarn app:web",
    "app:ext:op": "yarn op yarn app:ext",
    "app:desktop:op": "yarn op yarn app:desktop",
    "app:ios:op": "yarn op yarn app:ios",
    "app:android:op": "yarn op yarn app:android",
    "app:native-bundle:op": "yarn op yarn app:native-bundle",
    "keyless:mock-server:build": "yarn workspace @onekeyhq/kit-bg keyless:mock-server:build",
    "keyless:mock-server:start": "yarn keyless:mock-server:build && node packages/kit-bg/dist/keyless-cloud-sync-mock-server/cli.js"
  },
