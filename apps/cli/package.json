{
  "name": "@onekeyfe/cli",
  "version": "0.1.0-alpha.9",
  "description": "OneKey wallet CLI for developers and AI agents",
  "bin": {
    "onekey": "./bin/onekey"
  },
  "main": "dist/cli.js",
  "files": [
    "dist/",
    "bin/"
  ],
  "scripts": {
    "build": "tsup && node scripts/assert-no-deprecated-buffer.js",
    "dev": "tsup --watch",
    "test": "yarn test:unit && yarn test:integration:cli",
    "test:unit": "npx jest",
    "test:integration:cli": "yarn build && npx jest --runInBand --runTestsByPath src/__tests__/cli.integration.test.ts --testPathIgnorePatterns='-smoke\\.test\\.ts$'",
    "typecheck": "npx tsc --noEmit",
    "prepublishOnly": "yarn build",
    "package:macos-standalone": "yarn build && node scripts/package-macos-standalone.js",
    "version:patch": "node scripts/bump-version.js patch",
    "version:minor": "node scripts/bump-version.js minor",
    "version:major": "node scripts/bump-version.js major",
    "version:alpha": "node scripts/bump-version.js alpha",
    "version:beta": "node scripts/bump-version.js beta",
    "generate:cli-types": "node -r esbuild-register scripts/generate-cli-types.ts"
  },
  "devDependencies": {
    "@onekeyhq/core": "workspace:*",
    "@onekeyhq/shared": "workspace:*",
    "@types/proper-lockfile": "^4",
    "axios": "1.15.2",
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "expect-type": "^1.3.0",
    "postject": "1.0.0-alpha.6",
    "qrcode": "^1.5.0",
    "tsup": "^8.0.0",
    "yaml": "^2.8.0",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.25.2",
    "zod-to-ts": "^2.0.0"
  },
  "dependencies": {
    "@napi-rs/keyring": "^1.3.0",
    "@onekeyfe/hd-common-connect-sdk": "1.1.27",
    "@onekeyfe/hd-core": "1.1.27",
    "@onekeyfe/hd-transport-usb": "1.1.27",
    "proper-lockfile": "^4.1.2"
  }
}
