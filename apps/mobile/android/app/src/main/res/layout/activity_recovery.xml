<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F0F">

    <!-- Main content centered -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal|center_vertical"
        android:paddingStart="40dp"
        android:paddingEnd="40dp">

        <!-- OneKey Logo -->
        <ImageView
            android:id="@+id/logo"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@mipmap/ic_launcher_round"
            android:contentDescription="OneKey Logo" />

        <!-- Title -->
        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="App Failed to Start"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="The app has failed to start multiple times. You can try the following options to resolve the issue."
            android:textColor="#8C8C8C"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingExtra="4dp" />

        <!-- Quick Fix Button (Primary) -->
        <Button
            android:id="@+id/btn_auto_repair"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/recovery_button_green"
            android:text="Quick Fix"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textAllCaps="false" />

        <!-- Dismiss Button (Secondary) -->
        <Button
            android:id="@+id/btn_try_again"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/recovery_button_dark"
            android:text="Dismiss"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textAllCaps="false" />

    </LinearLayout>

    <!-- Bottom bar pinned to bottom -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal|bottom"
        android:layout_marginBottom="24dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/version_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#666666"
            android:textSize="12sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:text="\u00B7"
            android:textColor="#444444"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/btn_export_logs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#666666"
            android:textSize="12sp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</FrameLayout>
