{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["es2023"],
    "outDir": "dist/keyless-cloud-sync-mock-server",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noImplicitAny": false,
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "src/services/ServicePrimeCloudSync/keylessCloudSyncMockServer/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
