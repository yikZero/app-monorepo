<!DOCTYPE html>
<html
  font-size="16px"
   <% if ( platform === 'ext' && filename === 'ui-popup.html' ) { %>
      style="min-height: 600px; min-width: 400px; margin: 0; overflow: auto;"
   <% } %>
>
  <head>
    <meta charset="utf-8" />
    <meta httpEquiv="X-UA-Compatible" content="IE=edge" />
    <!--
        This viewport works for phones with notches.
        It's optimized for gestures by disabling global zoom.
    -->
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, minimum-scale=1, maximum-scale=1.00001, viewport-fit=cover"
    />
    <title>OneKey</title>
    <meta name="theme-color" content="#ffffff" />
    <style>
      /* add global styles to packages/shared/src/web/index.css */
    </style>

    <% if ( (platform === 'desktop' || platform === 'web') && isDev ) { %>
    <script>
      // DEV-ONLY (gated by isDev — ZERO prod effect): pre-read the cold-start
      // cache from IndexedDB HERE, during HTML parse, while the main thread is
      // still free.
      //
      // WHY: the cold-start IDB read costs ~1.5s when it happens during the boot
      // JS storm (the IDB onsuccess callback is starved by jotaiInit / React /
      // render work), but only ~3ms pre-bundle. AND hydrate.ts skips cold-start
      // entirely in dev (production-only, to avoid schema drift between code
      // changes). This pre-read populates ONLY the webColdStartStorage in-memory
      // Map with the single `onekey_jotai_context_atoms_snapshot` blob — NOT the
      // `__ONEKEY_CTX_ATOM_SNAPSHOT__` global — so the self-contained,
      // currency-gated, provisional SLC token-list slim cold-start activates in
      // dev for local verification, while the generic L2 context-atom hydration
      // (the schema-drift-prone part) stays OFF. Prod keeps its real hydrate.ts
      // path untouched.
      (function () {
        try {
          var DBN = 'onekey-cold-start-cache';
          var SNAP_KEY = 'onekey_jotai_context_atoms_snapshot';
          navigator.storageBuckets
            .open(DBN, { persisted: true, durability: 'strict' })
            .then(function (bk) {
              return new Promise(function (res, rej) {
                var r = bk.indexedDB.open(DBN, 1);
                r.onupgradeneeded = function () {
                  try { r.result.createObjectStore('kv'); } catch (e) {}
                };
                r.onsuccess = function () { res(r.result); };
                r.onerror = function () { rej(r.error); };
              });
            })
            .then(function (db) {
              return new Promise(function (res, rej) {
                var tx = db.transaction('kv', 'readonly');
                var req = tx.objectStore('kv').get(SNAP_KEY);
                req.onsuccess = function () {
                  try { db.close(); } catch (e) {}
                  res(req.result);
                };
                req.onerror = function () { rej(req.error); };
              });
            })
            .then(function (blob) {
              if (typeof blob !== 'string') return;
              var g = globalThis;
              var map = g.__ONEKEY_COLD_START_CACHE_MAP__;
              if (!map) { map = new Map(); g.__ONEKEY_COLD_START_CACHE_MAP__ = map; }
              // Do NOT clobber a value a facade write may already have set.
              if (!map.has(SNAP_KEY)) map.set(SNAP_KEY, blob);
            })
            .catch(function () { /* best-effort: no cold paint, no harm */ });
        } catch (e) { /* storageBuckets unsupported -> no-op */ }
      })();
    </script>
    <% } %>

      <% if ( platform === 'ext' ) { %>
      <!--    <script>-->
      <!--      // ** inline script not allowed in Ext, use themePreload.js instead-->
      <!--    </script>-->
          <script src="/preload-html-head.js?<%= currentVersion %>"></script>
      <% } %>

      <% if ( platform === 'desktop' || platform === 'web' ) { %>
          <script>
// >>>>>>> automatic copy code from preload-html-head.js <<<<<<<<<
            <%= htmlHeadPreloadCode %>
          </script>
      <% } %>
      <% if ( platform == 'web-embed' ) { %> 
        <script>
          if (typeof globalThis === 'undefined') {
              var globalThis = window;
          }
        </script>
      <% } %>
      <% if ( platform !== 'ext' ) { %>
        <script>
          if (typeof window.$$onekeyStartupTimeAt === 'undefined') {
            window.$$onekeyStartupTimeAt = Date.now();
          }
        </script>
      <% } %>
  </head>

  <!-- html template copy from node_modules/@expo/webpack-config/web-default/index.html -->
  <body class="onekey-body"

        data-platform="<%= platform %>"
        data-browser="<%= browser %>"
        data-filename="<%= filename %>-not-correct-in-ext"
    <% if ( platform === 'ext' && browser === 'firefox' && filename === 'ui-popup.html' ) { %>
        style="min-height: 600px; min-width: 400px; margin: 0;"
    <% } %>
  >

    <!--
      A generic no script element with a reload button and a message.
      Feel free to customize this however you'd like.
    -->
    <noscript>
      <form
        action=""
        style="
          background-color: #fff;
          position: fixed;
          top: 0;
          left: 0;
          right: 0;
          bottom: 0;
          z-index: 9999;
        "
      >
        <div
          style="
            font-size: 18px;
            font-family: Helvetica, sans-serif;
            line-height: 24px;
            margin: 10%;
            width: 80%;
          "
        >
          <p>Oh no! It looks like JavaScript is not enabled in your browser.</p>
          <p style="margin: 20px 0">
            <button
              type="submit"
              style="
                background-color: #4630eb;
                border-radius: 100px;
                border: none;
                box-shadow: none;
                color: #fff;
                cursor: pointer;
                font-weight: bold;
                line-height: 20px;
                padding: 6px 16px;
              "
            >
              Reload
            </button>
          </p>
        </div>
      </form>
    </noscript>

    <!-- The root element for your Expo app.  -->
    <div id="root">
      <% if ( platform == 'web-embed' ) { %> 
        <!-- webEmbed index.html -->
      <% } %>
    </div>

    <% if ( platform !== 'ext' ) { %>
      <script>
        (()=>{
          const rootElement = document.getElementById('root');
          if (rootElement) {
            rootElement.setAttribute('data-html-render-time', Date.now().toString());
          }
        })();
      </script>
    <% } %>

    <% if ( platform !== 'web-embed' && platform !== 'web' ) { %>
      <img
        width='80'
        class="onekey-index-html-preload-image"
        style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%)"
        src="data:image/png;base64,"
      />
    <% } %>
  </body>
</html>
