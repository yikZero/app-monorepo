+static NSString *OKOriginDomainKey(NSString *scheme, NSString *host) {
+  NSString *normalizedScheme = [scheme.lowercaseString copy];
+  if (![normalizedScheme isEqualToString:@"https"] && ![normalizedScheme isEqualToString:@"http"]) {
+    return nil;
+  }
+
+  NSString *domainKey = OKHostnameDomainKey(host);
+  if (domainKey.length == 0) {
+    return nil;
+  }
+
+  return [NSString stringWithFormat:@"%@://%@", normalizedScheme, domainKey];
+}
