+static NSString *OKHostnameDomainKey(NSString *hostname) {
+  NSString *normalizedHostname = OKNormalizeHostname(hostname);
+  if (normalizedHostname.length == 0) {
+    return nil;
+  }
+  if (OKIsIPHostname(normalizedHostname)) {
+    return normalizedHostname;
+  }
+
+  NSArray<NSString *> *labels = [normalizedHostname componentsSeparatedByString:@"."];
+  if (labels.count <= 2) {
+    return normalizedHostname;
+  }
+
+  NSString *topLevelLabel = labels.lastObject;
+  NSString *secondLevelLabel = labels[labels.count - 2];
+  if (topLevelLabel.length == 2 && secondLevelLabel.length <= 3 && labels.count >= 3) {
+    return [NSString stringWithFormat:@"%@.%@.%@", labels[labels.count - 3], secondLevelLabel, topLevelLabel];
