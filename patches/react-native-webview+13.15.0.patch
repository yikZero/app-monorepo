+static BOOL OKIsIPHostname(NSString *hostname) {
+  if ([hostname containsString:@":"]) {
+    return YES;
+  }
+
+  NSArray<NSString *> *segments = [hostname componentsSeparatedByString:@"."];
+  if (segments.count != 4) {
+    return NO;
+  }
+
+  NSCharacterSet *nonDigits = [[NSCharacterSet decimalDigitCharacterSet] invertedSet];
+  for (NSString *segment in segments) {
