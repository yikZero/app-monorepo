@@ -1,17 +1,28 @@
 #include <worklets/Tools/FeatureFlags.h>
 
+#include <mutex>
 #include <string>
 #include <unordered_map>
 
 namespace worklets {
 
 std::unordered_map<std::string, bool> DynamicFeatureFlags::flags_;
+// flags_ is a process-global static map accessed concurrently from multiple
+// worklet/JS runtimes (OneKey: main + background JS runtimes + reanimated UI
+// worklet runtime). Without locking, concurrent setFlag() calls during startup
+// trigger simultaneous emplace/rehash on the same table and corrupt its
+// internal buckets, producing a SIGSEGV in
+// std::__hash_table::__emplace_unique_key_args. flagsMutex_ serializes all
+// reads/writes of flags_.
+std::mutex DynamicFeatureFlags::flagsMutex_;
 
 bool DynamicFeatureFlags::getFlag(const std::string &name) {
+  std::lock_guard<std::mutex> lock(flagsMutex_);
   return flags_.contains(name) && flags_[name];
 }
 
 void DynamicFeatureFlags::setFlag(const std::string &name, bool value) {
+  std::lock_guard<std::mutex> lock(flagsMutex_);
   flags_[name] = value;
 }
 
