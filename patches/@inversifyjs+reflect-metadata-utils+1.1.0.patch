+exports.getOwnMetadata = getOwnMetadata;
+exports.getMetadata = getMetadata;
+exports.setMetadata = setMetadata;
+const store = new WeakMap();
+function setMetadata(target, metadataKey, metadata) {
+    let map = store.get(target);
+    if (map === undefined) {
+        map = new Map();
+        store.set(target, map);
+    }
+    map.set(metadataKey, metadata);
+}
+function getOwnMetadata(target, metadataKey) {
+    const map = store.get(target);
+    return map === undefined ? undefined : map.get(metadataKey);
+}
+function getMetadata(target, metadataKey) {
+    let current = target;
+    while (current !== null && current !== undefined) {
+        const map = store.get(current);
+        if (map !== undefined && map.has(metadataKey)) {
+            return map.get(metadataKey);
+        }
+        current = Object.getPrototypeOf(current);
+    }
+    return undefined;
+}
