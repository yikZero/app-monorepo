+static NSNotificationName const RNSBottomTabsContainerDidReattachNotification =
+    @"RNCTabViewContainerDidReattachNotification";
+
+static NSString *RNSSceneSummary(UIWindow *window)
+{
+#if TARGET_OS_IOS || TARGET_OS_TV || TARGET_OS_VISION
+  if (window == nil) {
+    return @"scene=nil";
+  }
+  if (@available(iOS 13.0, tvOS 13.0, *)) {
+    UIScene *scene = window.windowScene;
+    if (scene == nil) {
+      return @"scene=nil(windowHasNoScene)";
+    }
+    NSString *state = @"unknown";
+    switch (scene.activationState) {
+      case UISceneActivationStateForegroundActive:
+        state = @"foregroundActive";
+        break;
+      case UISceneActivationStateForegroundInactive:
+        state = @"foregroundInactive";
+        break;
+      case UISceneActivationStateBackground:
+        state = @"background";
+        break;
+      case UISceneActivationStateUnattached:
+        state = @"unattached";
+        break;
+    }
+    return [NSString stringWithFormat:@"scene=%p state=%@", scene, state];
+  }
+#endif
+  return @"scene=unavailable";
+}
