+- (void)schedulePendingContainerUpdateRetry:(NSString *)reason
+{
+  __weak RNSScreenStackView *weakSelf = self;
+  dispatch_async(dispatch_get_main_queue(), ^{
+    RNSScreenStackView *strongSelf = weakSelf;
+    if (!strongSelf || !strongSelf->_pendingContainerUpdate) {
+      return;
+    }
+
+    UIViewController *parentVC = strongSelf->_controller.parentViewController;
+    const BOOL selfWindowReady = strongSelf.window != nil;
+    const BOOL superviewWindowReady = strongSelf.superview.window != nil;
+    const BOOL parentWindowReady = parentVC.viewIfLoaded.window != nil;
+    const BOOL ready = [strongSelf isContainerWindowReady];
+
+    RNSScreenStackLog([NSString stringWithFormat:@"schedulePendingContainerUpdateRetry: reason=%@, requestId=%ld, pending=%d, ready=%d, selfWindow=%@, superviewWindow=%@, parentWindow=%@, retryScheduled=%d, retryCount=%ld, %@",
+                                                 reason ?: @"NIL",
+                                                 (long)strongSelf->_pendingContainerUpdateRequestId,
+                                                 strongSelf->_pendingContainerUpdate,
+                                                 ready,
+                                                 selfWindowReady ? @"YES" : @"NIL",
+                                                 superviewWindowReady ? @"YES" : @"NIL",
+                                                 parentWindowReady ? @"YES" : @"NIL",
+                                                 strongSelf->_pendingUpdateRetryScheduled,
+                                                 (long)strongSelf->_pendingUpdateRetryCount,
+                                                 RNSSceneSummary(strongSelf.window)]);
+
+    if (ready) {
+      strongSelf->_pendingContainerUpdate = NO;
+      strongSelf->_pendingUpdateRetryScheduled = NO;
+      strongSelf->_pendingUpdateRetryCount = 0;
+      strongSelf->_pendingContainerUpdateRequestId = 0;
+      [strongSelf updateContainer];
+      return;
+    }
+
+    if (strongSelf->_pendingUpdateRetryScheduled) {
+      return;
+    }
+
+    static const NSInteger kMaxPendingRetryCount = 50;
+    static const int64_t kPendingRetryDelayMs = 100;
+    if (strongSelf->_pendingUpdateRetryCount >= kMaxPendingRetryCount) {
+      RNSScreenStackLog([NSString stringWithFormat:@"schedulePendingContainerUpdateRetry: giving up after %ld retries (requestId=%ld)",
+                                                   (long)strongSelf->_pendingUpdateRetryCount,
+                                                   (long)strongSelf->_pendingContainerUpdateRequestId]);
+      RCTLogWarn(@"[RNSScreenStack] pendingContainerUpdate retries exhausted (%ld). "
+                 "This usually means goBack()/pop was called on a navigation stack inside a "
+                 "detached native tab view (UITabBarController). The stack's window is NIL so "
+                 "updates cannot be applied. Use resetAboveMainRoute() instead of sequential "
+                 "goBack() calls when dismissing overlay routes to avoid this race condition.",
+                 (long)kMaxPendingRetryCount);
+      return;
+    }
+
+    strongSelf->_pendingUpdateRetryScheduled = YES;
+    strongSelf->_pendingUpdateRetryCount += 1;
+    const NSInteger retryCount = strongSelf->_pendingUpdateRetryCount;
+    const NSInteger requestIdAtSchedule = strongSelf->_pendingContainerUpdateRequestId;
+    dispatch_after(dispatch_time(DISPATCH_TIME_NOW, (int64_t)(kPendingRetryDelayMs * NSEC_PER_MSEC)),
+                   dispatch_get_main_queue(),
+                   ^{
+      RNSScreenStackView *innerSelf = weakSelf;
+      if (!innerSelf) {
+        return;
+      }
+      innerSelf->_pendingUpdateRetryScheduled = NO;
+      if (!innerSelf->_pendingContainerUpdate) {
+        innerSelf->_pendingUpdateRetryCount = 0;
+        return;
+      }
+      if (innerSelf->_pendingContainerUpdateRequestId != requestIdAtSchedule) {
+        RNSScreenStackLog([NSString stringWithFormat:@"schedulePendingContainerUpdateRetry: stale retry timer ignored (scheduledRequestId=%ld, currentRequestId=%ld)",
+                                                     (long)requestIdAtSchedule,
+                                                     (long)innerSelf->_pendingContainerUpdateRequestId]);
+        return;
+      }
+      RNSScreenStackLog([NSString stringWithFormat:@"schedulePendingContainerUpdateRetry: retry timer fired (%ld/%ld) requestId=%ld",
+                                                   (long)retryCount,
+                                                   (long)kMaxPendingRetryCount,
+                                                   (long)requestIdAtSchedule]);
+      [innerSelf schedulePendingContainerUpdateRetry:@"retry-timer-fired"];
+    });
+  });
+}
+
+- (void)markPendingContainerUpdateWithReason:(NSString *)reason
+{
+  NSInteger previousRequestId = _pendingContainerUpdateRequestId;
+  _pendingContainerUpdateSeq += 1;
+  _pendingContainerUpdateRequestId = _pendingContainerUpdateSeq;
+  _pendingContainerUpdate = YES;
+  _pendingUpdateRetryScheduled = NO;
+  _pendingUpdateRetryCount = 0;
+  RNSScreenStackLog([NSString stringWithFormat:@"pendingContainerUpdate marked: reason=%@, requestId=%ld, previousRequestId=%ld, %@",
+                                               reason ?: @"NIL",
+                                               (long)_pendingContainerUpdateRequestId,
+                                               (long)previousRequestId,
+                                               RNSSceneSummary(self.window)]);
+}
+
+- (void)onApplicationDidBecomeActive:(NSNotification *)notification
+{
+  if (!_pendingContainerUpdate) {
