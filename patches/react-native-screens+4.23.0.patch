+- (void)onBottomTabsContainerDidReattach:(NSNotification *)notification
+{
+  if (!_pendingContainerUpdate) {
+    return;
+  }
+  NSString *reason = notification.userInfo[@"reason"];
+  UIViewController *parentVC = _controller.parentViewController;
+  RNSScreenStackLog([NSString
+      stringWithFormat:@"onBottomTabsContainerDidReattach: reason=%@, requestId=%ld, scheduling retry (selfWindow=%@, superviewWindow=%@, parentWindow=%@, parentVC=%@, %@)",
+                       reason ?: @"NIL",
+                       (long)_pendingContainerUpdateRequestId,
+                       self.window ? @"YES" : @"NIL",
+                       self.superview.window ? @"YES" : @"NIL",
+                       parentVC.viewIfLoaded.window ? @"YES" : @"NIL",
+                       parentVC ? NSStringFromClass([parentVC class]) : @"NIL",
+                       RNSSceneSummary(self.window)]);
+  [self schedulePendingContainerUpdateRetry:@"bottom-tabs-container-reattached"];
+}
