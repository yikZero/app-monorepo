+  __weak RNSScreenStackView *weakSelf = self;
+  dispatch_after(dispatch_time(DISPATCH_TIME_NOW, (int64_t)(16 * NSEC_PER_MSEC)), dispatch_get_main_queue(), ^{
+    RNSScreenStackView *strongSelf = weakSelf;
+    if (!strongSelf) {
+      return;
+    }
+
+    strongSelf->_pendingUpdateRetryScheduled = NO;
+
+    if (!strongSelf->_pendingContainerUpdate) {
+      strongSelf->_pendingUpdateRetryCount = 0;
+      return;
+    }
+
+    UIViewController *parentVC = strongSelf->_controller.parentViewController;
+    const BOOL windowReady = [strongSelf isAnyWindowReadyForContainerUpdate];
+    const BOOL transitionBusy = strongSelf->_controller.transitionCoordinator != nil;
+    CFAbsoluteTime now = CFAbsoluteTimeGetCurrent();
+    if (transitionBusy) {
+      if (strongSelf->_transitionBusySince == 0) {
+        strongSelf->_transitionBusySince = now;
+        RNSScreenStackLog(@"schedulePendingContainerUpdateRetry: transition busy start");
+      }
+    } else if (strongSelf->_transitionBusySince > 0) {
+      RNSScreenStackLog([NSString
+          stringWithFormat:@"schedulePendingContainerUpdateRetry: transition busy end, duration=%.3fs",
+                           now - strongSelf->_transitionBusySince]);
+      strongSelf->_transitionBusySince = 0;
+    }
+    const BOOL shouldRetryLater = !windowReady || transitionBusy;
+
+    RNSScreenStackLog([NSString
+        stringWithFormat:@"schedulePendingContainerUpdateRetry: reason=%@, pending=%d, ready=%@, transition=%@, retryCount=%ld, selfWindow=%@, superviewWindow=%@, parentWindow=%@, attached=%d",
+                         reason ?: @"NIL",
+                         strongSelf->_pendingContainerUpdate,
+                         windowReady ? @"YES" : @"NIL",
+                         transitionBusy ? @"YES" : @"NIL",
+                         (long)strongSelf->_pendingUpdateRetryCount,
+                         strongSelf.window ? @"YES" : @"NIL",
+                         strongSelf.superview.window ? @"YES" : @"NIL",
+                         parentVC.viewIfLoaded.window ? @"YES" : @"NIL",
+                         parentVC != nil]);
+
+    if (shouldRetryLater) {
+      strongSelf->_pendingUpdateRetryCount += 1;
+      if (strongSelf->_pendingUpdateRetryCount > 300) {
+        RNSScreenStackLog(@"schedulePendingContainerUpdateRetry: retry limit reached, stop polling (will retry on lifecycle events)");
+        strongSelf->_pendingUpdateRetryCount = 0;
+        return;
+      }
+      if (strongSelf->_pendingUpdateRetryCount % 60 == 0) {
+        RNSScreenStackLog([NSString
+            stringWithFormat:@"schedulePendingContainerUpdateRetry: still waiting after %ld retries, keep retrying",
+                             (long)strongSelf->_pendingUpdateRetryCount]);
